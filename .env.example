# VICIdial Docker Environment Configuration

# Database Configuration
MYSQL_ROOT_PASSWORD=VICIdial123!
VICIDIAL_DB_USER=vicidial
VICIDIAL_DB_PASSWORD=vicidial
VICIDIAL_DB_NAME=vicidial

# Asterisk Configuration
ASTERISK_VERSION=16.30.1
ASTERISK_USER=asterisk
ASTERISK_GROUP=asterisk

# VICIdial Configuration
VICIDIAL_VERSION=latest
VICIDIAL_ADMIN_USER=admin
VICIDIAL_ADMIN_PASSWORD=admin

# Apache Configuration
APACHE_RUN_USER=www-data
APACHE_RUN_GROUP=www-data
APACHE_LOG_DIR=/var/log/apache2

# Debian Configuration
DEBIAN_FRONTEND=noninteractive

# System Locale
LANG=en_US.UTF-8
LANGUAGE=en_US:en
LC_ALL=en_US.UTF-8

# Timezone
TZ=UTC

# Container Configuration
CONTAINER_TIMEZONE=UTC
